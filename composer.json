{
    "name": "alengo/order-search",
    "description": "Adds a search field to the order history in the customer account",
    "type": "shopware-platform-plugin",
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "alengo OG",
            "homepage": "https://www.alengo.at",
            "role": "Manufacturer"
        }
    ],
    "require": {
        "shopware/core": "^6.5.8",
        "shopware/storefront": "^6.5.8"
    },
    "extra": {
        "shopware-plugin-class": "AlengoOrderSearch\\AlengoOrderSearch",
        "plugin-icon": "src/Resources/config/plugin.png",
        "copyright": "(c) by alengo OG",
        "label": {
            "de-DE": "alengo Bestellsuche",
            "en-GB": "alengo Order Search"
        }
    },
    "autoload": {
        "psr-4": {
            "AlengoOrderSearch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AlengoOrderSearch\\Tests\\": "tests/"
        }
    }
}
